# คัดลอกเป็น .env แล้วเปลี่ยนค่า
# tags ที่มีจริง: :dev (main ล่าสุด), :vX.Y.Z (release semver)
# ไม่มี :latest — อย่าใส่ :latest จะเจอ unauthorized
AISIX_IMAGE=suriyaruk/aisix
RUST_LOG=info

# ใช้สร้าง admin key สุ่ม (จะถูก inject เข้า config.yaml ตอน deploy)
# generate ด้วย: openssl rand -hex 16
ADMIN_KEY=12333
